# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Risk thresholds (0–100) ───────────────────────────────────────────────────
# Transactions below SCORE_APPROVE are auto-approved
SCORE_APPROVE=40
# Transactions above SCORE_BLOCK are auto-blocked; between = manual review
SCORE_BLOCK=70

# ── Geolocation ───────────────────────────────────────────────────────────────
# Free tier: 45 req/min. Replace with MaxMind for production.
# GEOIP_PROVIDER=ip-api.com

# ── Data paths ────────────────────────────────────────────────────────────────
# HISTORY_FILE=data/transactions.json
# BLOCKED_FILE=data/blocked.json
# MODELS_DIR=models/
